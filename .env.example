# Kiro Suite - Configuração

# Chave de API do Gateway (use uma senha forte)
GATEWAY_API_KEY=minha-chave-secreta-aqui

# Região AWS (padrão: us-east-1)
KIRO_REGION=us-east-1

# Diretório de dados persistentes
APP_RUNTIME_BIND=./data

# Tipo de browser para automação (camoufox ou chromium)
SOLVER_BROWSER_TYPE=camoufox

# Nível de log (INFO, DEBUG, WARNING)
LOG_LEVEL=INFO
